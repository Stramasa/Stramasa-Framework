---
export interface Props {
  title: string;
  excerpt: string;
  industry: string;
  result: string;
  href: string;
  imageSrc?: string;
}

const { title, excerpt, industry, result, href, imageSrc } = Astro.props;
---

<article class="case-card">
  {imageSrc && (
    <div class="case-image">
      <img src={imageSrc} alt={title} width="400" height="240" loading="lazy" />
    </div>
  )}
  <div class="case-body">
    <span class="case-industry">{industry}</span>
    <h3><a href={href}>{title}</a></h3>
    <p>{excerpt}</p>
    <div class="case-result">
      <span class="result-label">Key Result</span>
      <span class="result-value">{result}</span>
    </div>
    <a href={href} class="case-link">
      Read Case Study
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
    </a>
  </div>
</article>

<style>
  .case-card {
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: box-shadow 0.2s, transform 0.2s;
  }

  .case-card:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-3px);
  }

  .case-image img {
    width: 100%;
    height: 200px;
    object-fit: cover;
  }

  .case-body { padding: 28px; }

  .case-industry {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    background: var(--gradient-primary);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 12px;
  }

  .case-body h3 {
    font-size: 1.125rem;
    margin-bottom: 10px;
  }

  .case-body h3 a {
    color: var(--charcoal-900);
    text-decoration: none;
  }

  .case-body h3 a:hover { text-decoration: underline; }

  .case-body p {
    font-size: 0.9375rem;
    color: var(--charcoal-600);
    margin-bottom: 20px;
    line-height: 1.65;
  }

  .case-result {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 16px;
    background: linear-gradient(135deg, rgba(37,99,235,0.06), rgba(20,184,166,0.06));
    border-radius: var(--radius-md);
    margin-bottom: 20px;
  }

  .result-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--gray-500);
  }

  .result-value {
    font-size: 1rem;
    font-weight: 700;
    color: var(--charcoal-900);
  }

  .case-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--blue-600);
    text-decoration: none;
  }

  .case-link:hover { text-decoration: underline; }
</style>
