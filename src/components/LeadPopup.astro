---
// No props — all logic is client-side
---

<div id="lead-popup-overlay" class="lp-overlay" role="dialog" aria-modal="true" aria-labelledby="lp-title" aria-hidden="true">
  <div class="lp-card" id="lead-popup-card">
    <button class="lp-close" id="lp-close" aria-label="Close">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 6L6 18M6 6l12 12"/></svg>
    </button>

    <div class="lp-eyebrow">Free Consultation</div>
    <h2 class="lp-title" id="lp-title">Let's Talk About Your Project</h2>
    <p class="lp-sub">Tell us what you're working on — one of our experts will reach out personally to explore how we can help.</p>

    <form id="lp-form" class="lp-form" novalidate>
      <div class="lp-field">
        <label for="lp-name">Your Name</label>
        <input type="text" id="lp-name" name="name" placeholder="Jane Smith" autocomplete="given-name" required />
      </div>
      <div class="lp-field">
        <label for="lp-email">Work Email</label>
        <input type="email" id="lp-email" name="email" placeholder="jane@company.com" autocomplete="email" required />
      </div>
      <div class="lp-field">
        <label for="lp-message">What are you looking to achieve?</label>
        <textarea id="lp-message" name="message" rows="3" placeholder="Give us a quick overview of your project or goals…" required></textarea>
      </div>
      <div id="lp-error" class="lp-error" role="alert" aria-live="polite"></div>
      <button type="submit" class="lp-submit btn btn-primary" id="lp-submit">
        <span id="lp-submit-label">Send My Request</span>
        <svg id="lp-spinner" class="lp-spinner" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="display:none"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg>
      </button>
    </form>

    <div id="lp-success" class="lp-success" style="display:none">
      <div class="lp-success-icon" aria-hidden="true">
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
      </div>
      <h3>You're all set!</h3>
      <p>We've received your request and will be in touch within one business day. We look forward to learning more about your project.</p>
    </div>

    <p class="lp-privacy">No spam, ever. We respect your privacy.</p>
  </div>
</div>

<style>
  .lp-overlay {
    position: fixed;
    inset: 0;
    z-index: 9000;
    background: rgba(15, 15, 30, 0.55);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease;
    backdrop-filter: blur(3px);
    -webkit-backdrop-filter: blur(3px);
  }

  .lp-overlay.lp-visible {
    opacity: 1;
    visibility: visible;
  }

  .lp-card {
    position: relative;
    background: var(--white);
    border-radius: var(--radius-xl);
    padding: 48px 44px 36px;
    max-width: 500px;
    width: 100%;
    box-shadow: 0 24px 64px rgba(0, 0, 0, 0.22);
    transform: translateY(20px) scale(0.97);
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .lp-overlay.lp-visible .lp-card {
    transform: translateY(0) scale(1);
  }

  .lp-close {
    position: absolute;
    top: 16px;
    right: 16px;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: none;
    background: var(--gray-100);
    color: var(--gray-500);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s, color 0.15s;
  }

  .lp-close:hover {
    background: var(--gray-200);
    color: var(--charcoal-900);
  }

  .lp-eyebrow {
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    background: var(--gradient-primary);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 10px;
  }

  .lp-title {
    font-size: 1.625rem;
    color: var(--charcoal-900);
    margin-bottom: 10px;
    line-height: 1.25;
  }

  .lp-sub {
    font-size: 0.9375rem;
    color: var(--charcoal-600);
    line-height: 1.65;
    margin-bottom: 28px;
  }

  .lp-form { display: flex; flex-direction: column; gap: 16px; }

  .lp-field { display: flex; flex-direction: column; gap: 6px; }

  .lp-field label {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--charcoal-800);
  }

  .lp-field input,
  .lp-field textarea {
    border: 1.5px solid var(--gray-200);
    border-radius: var(--radius-md);
    padding: 11px 14px;
    font-size: 0.9375rem;
    font-family: inherit;
    color: var(--charcoal-900);
    background: var(--white);
    transition: border-color 0.15s, box-shadow 0.15s;
    resize: vertical;
    outline: none;
  }

  .lp-field input:focus,
  .lp-field textarea:focus {
    border-color: var(--blue-500);
    box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.12);
  }

  .lp-field input::placeholder,
  .lp-field textarea::placeholder {
    color: var(--gray-400);
  }

  .lp-error {
    font-size: 0.875rem;
    color: #dc2626;
    min-height: 0;
    line-height: 1.4;
  }

  .lp-submit {
    width: 100%;
    justify-content: center;
    padding: 14px;
    font-size: 1rem;
    margin-top: 4px;
  }

  .lp-spinner {
    animation: lp-spin 0.7s linear infinite;
  }

  @keyframes lp-spin {
    to { transform: rotate(360deg); }
  }

  .lp-success {
    text-align: center;
    padding: 24px 0 8px;
  }

  .lp-success-icon {
    width: 72px;
    height: 72px;
    background: #ecfdf5;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 20px;
    color: #059669;
  }

  .lp-success h3 {
    font-size: 1.375rem;
    margin-bottom: 10px;
  }

  .lp-success p {
    font-size: 0.9375rem;
    color: var(--charcoal-600);
    line-height: 1.65;
  }

  .lp-privacy {
    font-size: 0.8125rem;
    color: var(--gray-400);
    text-align: center;
    margin-top: 16px;
  }

  @media (max-width: 580px) {
    .lp-card { padding: 40px 24px 28px; }
    .lp-title { font-size: 1.375rem; }
  }
</style>

<script>
  const STORAGE_KEY = 'lp_dismissed_at';
  const SUPPRESS_DAYS = 14;
  const SUPPRESS_MS = SUPPRESS_DAYS * 24 * 60 * 60 * 1000;

  function shouldShow(): boolean {
    try {
      const ts = localStorage.getItem(STORAGE_KEY);
      if (!ts) return true;
      return Date.now() - Number(ts) > SUPPRESS_MS;
    } catch {
      return true;
    }
  }

  function suppress() {
    try { localStorage.setItem(STORAGE_KEY, String(Date.now())); } catch {}
  }

  function openPopup() {
    const overlay = document.getElementById('lead-popup-overlay');
    if (!overlay) return;
    overlay.setAttribute('aria-hidden', 'false');
    overlay.classList.add('lp-visible');
    // Focus first input for accessibility
    const first = overlay.querySelector<HTMLElement>('input, textarea');
    if (first) setTimeout(() => first.focus(), 320);
  }

  function closePopup(suppressIt = true) {
    const overlay = document.getElementById('lead-popup-overlay');
    if (!overlay) return;
    overlay.classList.remove('lp-visible');
    overlay.setAttribute('aria-hidden', 'true');
    if (suppressIt) suppress();
  }

  function init() {
    if (!shouldShow()) return;

    const overlay = document.getElementById('lead-popup-overlay') as HTMLElement | null;
    const closeBtn = document.getElementById('lp-close');
    const form = document.getElementById('lp-form') as HTMLFormElement | null;
    const errorEl = document.getElementById('lp-error') as HTMLElement;
    const successEl = document.getElementById('lp-success') as HTMLElement;
    const submitBtn = document.getElementById('lp-submit') as HTMLButtonElement;
    const submitLabel = document.getElementById('lp-submit-label') as HTMLElement;
    const spinner = document.getElementById('lp-spinner') as HTMLElement;

    if (!overlay) return;

    let triggered = false;

    function trigger() {
      if (triggered) return;
      triggered = true;
      openPopup();
    }

    // --- 50% scroll trigger ---
    function onScroll() {
      const scrolled = window.scrollY + window.innerHeight;
      const total = document.documentElement.scrollHeight;
      if (scrolled / total >= 0.5) {
        trigger();
        window.removeEventListener('scroll', onScroll, { passive: true } as EventListenerOptions);
      }
    }
    window.addEventListener('scroll', onScroll, { passive: true });

    // --- Exit intent (desktop: mouse leaves viewport top) ---
    function onMouseOut(e: MouseEvent) {
      if (e.clientY <= 0 && !e.relatedTarget) {
        trigger();
        document.removeEventListener('mouseout', onMouseOut);
      }
    }
    document.addEventListener('mouseout', onMouseOut);

    // --- Close on X button ---
    closeBtn?.addEventListener('click', () => closePopup(true));

    // --- Close on overlay click (outside card) ---
    overlay.addEventListener('click', (e) => {
      if (e.target === overlay) closePopup(true);
    });

    // --- Close on Escape ---
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && overlay.classList.contains('lp-visible')) closePopup(true);
    });

    // --- Form submit ---
    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      errorEl.textContent = '';

      const name = (document.getElementById('lp-name') as HTMLInputElement).value.trim();
      const email = (document.getElementById('lp-email') as HTMLInputElement).value.trim();
      const message = (document.getElementById('lp-message') as HTMLTextAreaElement).value.trim();

      if (!name || !email || !message) {
        errorEl.textContent = 'Please fill in all fields.';
        return;
      }
      const emailOk = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
      if (!emailOk) {
        errorEl.textContent = 'Please enter a valid email address.';
        return;
      }

      submitBtn.disabled = true;
      submitLabel.textContent = 'Sending…';
      spinner.style.display = 'block';

      try {
        const res = await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name, email, message }),
        });
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Submission failed.');

        // Show success state
        form.style.display = 'none';
        successEl.style.display = 'block';
        suppress();
        // Auto-close after 4 seconds
        setTimeout(() => closePopup(false), 4000);
      } catch (err: unknown) {
        const msg = err instanceof Error ? err.message : 'Something went wrong. Please try again.';
        errorEl.textContent = msg;
        submitBtn.disabled = false;
        submitLabel.textContent = 'Send My Request';
        spinner.style.display = 'none';
      }
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>
