---
export interface Props {
  headline: string;
  subheadline: string;
  ctaLabel?: string;
  ctaHref?: string;
  ctaSecondaryLabel?: string;
  ctaSecondaryHref?: string;
  badge?: string;
  heroImageSrc?: string;
}

const {
  headline,
  subheadline,
  ctaLabel = 'Get Your Growth Strategy',
  ctaHref = '/contact/',
  ctaSecondaryLabel,
  ctaSecondaryHref,
  badge,
  heroImageSrc,
} = Astro.props;
---

<section class="hero">
  {heroImageSrc && (
    <div
      class="hero-bg-image"
      style={`background-image: url('${heroImageSrc}')`}
      role="presentation"
      aria-hidden="true"
    ></div>
  )}
  <div class="hero-overlay" aria-hidden="true"></div>
  <div class="container">
    <div class="hero-inner">
      <div class="hero-content">
        {badge && <span class="hero-badge">{badge}</span>}
        <h1 set:html={headline} />
        <p class="hero-sub">{subheadline}</p>
        <div class="hero-ctas">
          <a href={ctaHref} class="btn btn-primary" target="_blank" rel="noopener noreferrer">
            {ctaLabel}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          {ctaSecondaryLabel && ctaSecondaryHref && (
            <a href={ctaSecondaryHref} class="btn btn-outline-white">{ctaSecondaryLabel}</a>
          )}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    padding: 108px 0 88px;
    background: linear-gradient(135deg, #1a3ccc 0%, #1565c8 35%, #0a7ea4 70%, #0d9488 100%);
  }

  /* Photo layer — sits between the base gradient and the colour overlay */
  .hero-bg-image {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center 30%;
    opacity: 0.38;
    z-index: 0;
  }

  /* Directional gradient that keeps left-side text clear while letting the image show on right */
  .hero-overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(
        105deg,
        rgba(20, 42, 180, 0.88) 0%,
        rgba(20, 42, 180, 0.65) 45%,
        rgba(10, 126, 164, 0.40) 75%,
        rgba(13, 148, 136, 0.20) 100%
      );
    z-index: 1;
  }

  .hero-inner {
    position: relative;
    z-index: 2;
    max-width: 820px;
  }

  .hero-badge {
    display: inline-block;
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--teal-300);
    border: 1px solid rgba(94, 234, 212, 0.35);
    background: rgba(20, 184, 166, 0.12);
    border-radius: 100px;
    padding: 5px 14px;
    margin-bottom: 20px;
  }

  .hero-content h1 {
    color: var(--white);
    margin-bottom: 24px;
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    letter-spacing: -0.025em;
    text-shadow: 0 2px 24px rgba(0, 0, 0, 0.22);
  }

  .hero-content :global(.text-gradient) {
    background: linear-gradient(135deg, #5eead4 0%, #ccfbf1 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-sub {
    font-size: clamp(1.0625rem, 2vw, 1.2rem);
    color: rgba(255, 255, 255, 0.88);
    margin-bottom: 40px;
    max-width: 660px;
    line-height: 1.7;
    text-shadow: 0 1px 10px rgba(0, 0, 0, 0.15);
  }

  .hero-ctas {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  .btn-outline-white {
    display: inline-flex;
    align-items: center;
    padding: 14px 32px;
    border-radius: 8px;
    font-size: 1rem;
    font-weight: 600;
    border: 2px solid rgba(255, 255, 255, 0.55);
    color: var(--white);
    text-decoration: none;
    transition: border-color 0.2s, background 0.2s;
    line-height: 1;
    backdrop-filter: blur(4px);
    background: rgba(255, 255, 255, 0.07);
  }

  .btn-outline-white:hover {
    border-color: var(--white);
    background: rgba(255, 255, 255, 0.15);
    text-decoration: none;
  }

  @media (max-width: 640px) {
    .hero { padding: 80px 0 64px; }
    .hero-ctas { flex-direction: column; align-items: flex-start; }
  }
</style>
