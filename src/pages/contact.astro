---
import Layout from '../layouts/Layout.astro';
import GrowthHeader from '../components/GrowthHeader.astro';
import GrowthFooter from '../components/GrowthFooter.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import SchemaMarkup from '../components/SchemaMarkup.astro';

const CONTACT_ENDPOINT = '/api/contact';
---

<Layout
  title="Contact Stramasa | Book a Spiritual Marketing Strategy Call"
  description="Get in touch with Stramasa's spiritual marketing team. Book a free strategy call or send us a message — we work with churches, wellness brands, spiritual coaches, and faith-based organizations."
  canonical="/contact/"
  category="Contact"
>
  <SchemaMarkup
    type="WebSite"
    name="Contact Stramasa — Spiritual Marketing Growth Experts"
    description="Contact Stramasa's spiritual marketing team for a free strategy consultation."
    url="https://spiritual.stramasa.com/contact/"
  />

  <GrowthHeader />

  <div class="container">
    <Breadcrumbs crumbs={[
      { label: 'Home', href: '/' },
      { label: 'Contact' },
    ]} />
  </div>

  <!-- Hero -->
  <section class="contact-hero">
    <div class="container">
      <div class="contact-hero-inner">
        <span class="section-label">Get in Touch</span>
        <h1>Let's Talk About Your Growth</h1>
        <p class="hero-lead">Whether you're a church, wellness brand, spiritual teacher, or faith-based nonprofit — we'd love to hear about where you are and where you want to go. No pitch, no pressure. Just a real conversation.</p>
      </div>
    </div>
  </section>

  <!-- Main Content -->
  <section class="section">
    <div class="container contact-layout">

      <!-- Form -->
      <div class="form-panel">
        <h2>Send Us a Message</h2>
        <p class="form-intro">Fill in the form and we'll get back to you within one business day.</p>

        <form id="contact-form" class="contact-form" novalidate>
          <div class="field-row">
            <div class="field">
              <label for="name">Your Name <span class="required">*</span></label>
              <input type="text" id="name" name="name" placeholder="Jane Smith" autocomplete="name" required />
            </div>
            <div class="field">
              <label for="email">Email Address <span class="required">*</span></label>
              <input type="email" id="email" name="email" placeholder="jane@yourorganization.com" autocomplete="email" required />
            </div>
          </div>

          <div class="field-row">
            <div class="field">
              <label for="org">Organization / Brand</label>
              <input type="text" id="org" name="org" placeholder="Your Church, Studio, Brand..." autocomplete="organization" />
            </div>
            <div class="field">
              <label for="phone">Phone Number</label>
              <input type="tel" id="phone" name="phone" placeholder="+1 (555) 000-0000" autocomplete="tel" />
            </div>
          </div>

          <div class="field">
            <label for="message">Your Message <span class="required">*</span></label>
            <textarea id="message" name="message" rows="6" placeholder="Tell us about your organization, what you're working on, and what kind of help you're looking for..." required></textarea>
          </div>

          <div id="form-error" class="form-feedback error" aria-live="polite" style="display:none;"></div>
          <div id="form-success" class="form-feedback success" aria-live="polite" style="display:none;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            Your message was sent successfully. We'll be in touch within one business day.
          </div>

          <button type="submit" class="btn btn-primary submit-btn" id="submit-btn">
            <span class="btn-text">Send Message</span>
            <span class="btn-loading" style="display:none;">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="spin" aria-hidden="true"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>
              Sending...
            </span>
          </button>
        </form>
      </div>

      <!-- Sidebar info -->
      <aside class="contact-sidebar">
        <div class="sidebar-block">
          <h3>What to Expect</h3>
          <ul class="expect-list">
            <li>
              <span class="expect-num">1</span>
              <div>
                <strong>We review your message</strong>
                <p>Usually within a few hours. Always within one business day.</p>
              </div>
            </li>
            <li>
              <span class="expect-num">2</span>
              <div>
                <strong>We schedule an intro meeting</strong>
                <p>A focused conversation to understand your goals, challenges, and what growth looks like for your organization.</p>
              </div>
            </li>
            <li>
              <span class="expect-num">3</span>
              <div>
                <strong>We share our growth packages and get started</strong>
                <p>We present the right approach for your situation and hit the ground running together.</p>
              </div>
            </li>
          </ul>
        </div>

        <div class="sidebar-block">
          <h3>We Work With</h3>
          <div class="works-with">
            <a href="/church-marketing/" class="works-tag">Churches & Ministries</a>
            <a href="/wellness-marketing/" class="works-tag">Yoga Studios</a>
            <a href="/wellness-marketing/" class="works-tag">Retreat Centers</a>
            <a href="/spiritual-marketing/" class="works-tag">Spiritual Coaches</a>
            <a href="/wellness-marketing/" class="works-tag">Meditation Centers</a>
            <a href="/spiritual-branding/" class="works-tag">Faith Nonprofits</a>
            <a href="/spiritual-marketing/" class="works-tag">Wellness Brands</a>
            <a href="/spiritual-branding/" class="works-tag">Spiritual Teachers</a>
          </div>
        </div>

        <div class="sidebar-block direct-email">
          <h3>Prefer Email?</h3>
          <a href="mailto:info@stramasa.com" class="email-link">info@stramasa.com</a>
        </div>
      </aside>

    </div>
  </section>

  <!-- Calendly CTA -->
  <section class="calendly-section">
    <div class="container calendly-inner">
      <div class="calendly-content">
        <span class="section-label">Book Directly</span>
        <h2>Prefer to Skip the Back-and-Forth?</h2>
        <p>Book a time directly with our spiritual marketing experts. Pick a slot that works for you and we'll come prepared with ideas for your specific situation.</p>
        <a
          href="https://calendly.com/stramasa-agency/30min"
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-primary calendly-btn"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          Plan a Meeting with Our Team
        </a>
      </div>
      <div class="calendly-visual" aria-hidden="true">
        <div class="cal-card">
          <div class="cal-card-header">
            <div class="cal-dot"></div>
            <div class="cal-dot"></div>
            <div class="cal-dot"></div>
          </div>
          <div class="cal-body">
            <p class="cal-org">Stramasa Spiritual Marketing</p>
            <p class="cal-title">Intro Meeting</p>
            <div class="cal-times">
              <span class="cal-time active">9:00 AM</span>
              <span class="cal-time">9:30 AM</span>
              <span class="cal-time">10:00 AM</span>
              <span class="cal-time">10:30 AM</span>
              <span class="cal-time">2:00 PM</span>
              <span class="cal-time">2:30 PM</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <GrowthFooter />
</Layout>

<style>
  /* Hero */
  .contact-hero {
    padding: 80px 0 64px;
    background: var(--gradient-hero);
  }

  .contact-hero-inner { max-width: 720px; }

  .contact-hero .section-label {
    color: var(--teal-300);
    background: none;
    -webkit-text-fill-color: var(--teal-300);
  }

  .contact-hero h1 {
    color: var(--white);
    margin-top: 10px;
    margin-bottom: 20px;
    font-size: clamp(2rem, 4.5vw, 3rem);
  }

  .hero-lead {
    font-size: 1.125rem;
    color: rgba(255, 255, 255, 0.82);
    line-height: 1.75;
    margin: 0;
  }

  /* Layout */
  .contact-layout {
    display: grid;
    grid-template-columns: 1fr 360px;
    gap: 64px;
    align-items: start;
  }

  /* Form panel */
  .form-panel h2 { margin-bottom: 8px; font-size: 1.5rem; }

  .form-intro {
    color: var(--charcoal-600);
    font-size: 0.9375rem;
    margin-bottom: 32px;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .field-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .field label {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--charcoal-800);
  }

  .required { color: var(--teal-500); }

  .field input,
  .field textarea {
    padding: 12px 14px;
    font-size: 0.9375rem;
    font-family: inherit;
    color: var(--charcoal-900);
    background: var(--white);
    border: 1.5px solid var(--gray-200);
    border-radius: var(--radius-md);
    transition: border-color 0.15s, box-shadow 0.15s;
    outline: none;
    width: 100%;
  }

  .field input::placeholder,
  .field textarea::placeholder {
    color: var(--gray-400);
  }

  .field input:focus,
  .field textarea:focus {
    border-color: var(--blue-500);
    box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
  }

  .field textarea { resize: vertical; min-height: 140px; line-height: 1.6; }

  .form-feedback {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 14px 18px;
    border-radius: var(--radius-md);
    font-size: 0.9375rem;
    font-weight: 500;
  }

  .form-feedback.error {
    background: #fef2f2;
    border: 1px solid #fecaca;
    color: #b91c1c;
  }

  .form-feedback.success {
    background: #f0fdf4;
    border: 1px solid #bbf7d0;
    color: #15803d;
  }

  .submit-btn {
    align-self: flex-start;
    min-width: 180px;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }
  .spin { animation: spin 1s linear infinite; }

  /* Sidebar */
  .contact-sidebar {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .sidebar-block {
    background: var(--gray-50);
    border: 1px solid var(--gray-200);
    border-radius: var(--radius-lg);
    padding: 28px;
  }

  .sidebar-block h3 {
    font-size: 1rem;
    margin-bottom: 20px;
    color: var(--charcoal-900);
  }

  .expect-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .expect-list li {
    display: flex;
    gap: 14px;
    align-items: flex-start;
  }

  .expect-num {
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: var(--gradient-primary);
    color: var(--white);
    font-size: 0.8125rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 1px;
  }

  .expect-list strong {
    display: block;
    font-size: 0.9375rem;
    color: var(--charcoal-900);
    margin-bottom: 4px;
  }

  .expect-list p {
    font-size: 0.875rem;
    color: var(--charcoal-600);
    line-height: 1.55;
    margin: 0;
  }

  .works-with {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .works-tag {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--charcoal-700);
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: 100px;
    padding: 5px 14px;
    text-decoration: none;
    transition: border-color 0.15s, color 0.15s;
  }

  .works-tag:hover {
    border-color: var(--teal-400);
    color: var(--teal-500);
    text-decoration: none;
  }

  .direct-email h3 { margin-bottom: 10px; }

  .email-link {
    display: block;
    font-size: 1rem;
    font-weight: 600;
    color: var(--blue-600);
    text-decoration: none;
  }

  .email-link:hover { text-decoration: underline; }

  @media (max-width: 1024px) {
    .contact-layout { grid-template-columns: 1fr; gap: 48px; }
    .contact-sidebar { max-width: 560px; }
  }

  @media (max-width: 580px) {
    .field-row { grid-template-columns: 1fr; }
  }

  /* Calendly section */
  .calendly-section {
    padding: 80px 0;
    background: var(--gradient-hero);
  }

  .calendly-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 72px;
    align-items: center;
  }

  .calendly-content .section-label {
    color: var(--teal-300);
    background: none;
    -webkit-text-fill-color: var(--teal-300);
  }

  .calendly-content h2 {
    color: var(--white);
    margin-top: 10px;
    margin-bottom: 16px;
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
  }

  .calendly-content p {
    color: rgba(255,255,255,0.82);
    font-size: 1.0625rem;
    line-height: 1.75;
    margin-bottom: 32px;
  }

  .calendly-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: var(--white);
    color: var(--blue-700);
    font-weight: 700;
  }

  .calendly-btn:hover {
    background: var(--gray-50);
    color: var(--blue-700);
    text-decoration: none;
  }

  /* Decorative calendar card */
  .calendly-visual {
    display: flex;
    justify-content: center;
  }

  .cal-card {
    background: rgba(255,255,255,0.07);
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: var(--radius-xl);
    width: 100%;
    max-width: 320px;
    overflow: hidden;
    backdrop-filter: blur(8px);
  }

  .cal-card-header {
    display: flex;
    gap: 6px;
    padding: 14px 18px;
    background: rgba(255,255,255,0.05);
    border-bottom: 1px solid rgba(255,255,255,0.1);
  }

  .cal-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: rgba(255,255,255,0.25);
  }

  .cal-body { padding: 24px 20px; }

  .cal-org {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--teal-300);
    margin-bottom: 6px;
  }

  .cal-title {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--white);
    margin-bottom: 20px;
  }

  .cal-times {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
  }

  .cal-time {
    display: block;
    text-align: center;
    padding: 8px;
    border-radius: var(--radius-md);
    font-size: 0.875rem;
    font-weight: 500;
    color: rgba(255,255,255,0.7);
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    cursor: default;
  }

  .cal-time.active {
    background: var(--teal-500);
    color: var(--white);
    border-color: var(--teal-400);
  }

  @media (max-width: 900px) {
    .calendly-inner { grid-template-columns: 1fr; gap: 40px; }
    .calendly-visual { display: none; }
  }
</style>

<script define:vars={{ CONTACT_ENDPOINT }}>
  const form = document.getElementById('contact-form');
  const submitBtn = document.getElementById('submit-btn');
  const btnText = submitBtn?.querySelector('.btn-text');
  const btnLoading = submitBtn?.querySelector('.btn-loading');
  const errorBox = document.getElementById('form-error');
  const successBox = document.getElementById('form-success');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorBox.style.display = 'none';
    successBox.style.display = 'none';

    const name    = document.getElementById('name').value.trim();
    const email   = document.getElementById('email').value.trim();
    const org     = document.getElementById('org').value.trim();
    const phone   = document.getElementById('phone').value.trim();
    const message = document.getElementById('message').value.trim();

    if (!name || !email || !message) {
      errorBox.textContent = 'Please fill in your name, email, and message.';
      errorBox.style.display = 'flex';
      return;
    }

    submitBtn.disabled = true;
    btnText.style.display = 'none';
    btnLoading.style.display = 'flex';

    try {
      const res = await fetch(CONTACT_ENDPOINT, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name, email, org, phone, message }),
      });

      let data = {};
      try { data = await res.json(); } catch { /* non-JSON response */ }

      if (res.ok) {
        successBox.style.display = 'flex';
        form.reset();
      } else {
        errorBox.textContent = data.error ?? 'Something went wrong. Please email us at info@stramasa.com';
        errorBox.style.display = 'flex';
      }
    } catch {
      errorBox.textContent = 'Could not send message. Please email us directly at info@stramasa.com';
      errorBox.style.display = 'flex';
    } finally {
      submitBtn.disabled = false;
      btnText.style.display = '';
      btnLoading.style.display = 'none';
    }
  });
</script>
