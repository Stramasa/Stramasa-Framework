---
import Layout from '../../layouts/Layout.astro';
import GrowthHeader from '../../components/GrowthHeader.astro';
import GrowthFooter from '../../components/GrowthFooter.astro';
import CaseStudyCard from '../../components/CaseStudyCard.astro';
import CTASection from '../../components/CTASection.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import SchemaMarkup from '../../components/SchemaMarkup.astro';
---

<Layout
  title="Spiritual Marketing Case Studies | Stramasa Growth Programs"
  description="Real results from real spiritual brands. Explore how Stramasa's Growth Programs have helped meditation centers, faith nonprofits, churches, practitioners, and wellness businesses grow their digital presence."
  canonical="/case-studies/"
  category="Case Studies"
>
  <SchemaMarkup
    type="WebSite"
    name="Spiritual Marketing Case Studies"
    description="Case studies showing how Stramasa's Growth Programs drive measurable results for spiritual brands, practitioners, churches, and wellness organizations."
    url="https://spiritual.stramasa.com/case-studies/"
  />

  <GrowthHeader />

  <div class="container">
    <Breadcrumbs crumbs={[
      { label: 'Home', href: '/' },
      { label: 'Case Studies' },
    ]} />
  </div>

  <!-- Page Header -->
  <section class="page-header">
    <div class="container">
      <span class="section-label">Client Success Stories</span>
      <h1>Spiritual Marketing Case Studies</h1>
      <p class="page-lead">Real results from spiritual entrepreneurs, practitioners, churches, wellness businesses, and faith-based organizations that partnered with Stramasa's Growth Programs to build lasting digital authority.</p>
    </div>
  </section>

  <!-- Results Strip -->
  <section class="results-strip">
    <div class="container results-grid">
      <div class="result-stat">
        <span class="result-num">312%</span>
        <span class="result-lbl">Avg. organic traffic growth</span>
      </div>
      <div class="result-stat">
        <span class="result-num">2x</span>
        <span class="result-lbl">Donation revenue achieved</span>
      </div>
      <div class="result-stat">
        <span class="result-num">8 mo.</span>
        <span class="result-lbl">Average time to results</span>
      </div>
      <div class="result-stat">
        <span class="result-num">Top 3</span>
        <span class="result-lbl">Rankings for core terms</span>
      </div>
    </div>
  </section>

  <!-- Case Studies Grid -->
  <section class="section">
    <div class="container">
      <div class="case-studies-grid">

        <CaseStudyCard
          title="Spiritual Life Coach Quadruples Coaching Inquiries in 9 Months"
          excerpt="A respected spiritual life coach had deep expertise and an inconsistent digital presence that wasn't converting. Stramasa rebuilt her brand positioning, content, and lead system — her calendar is now oversubscribed."
          industry="Spiritual Coaching"
          result="4x coaching inquiry growth, 220% organic traffic increase"
          href="/case-studies/spiritual-coach-brand-growth/"
          imageSrc="https://images.pexels.com/photos/5717718/pexels-photo-5717718.jpeg?auto=compress&cs=tinysrgb&w=600"
        />

        <CaseStudyCard
          title="Conscious Speaker & Retreat Leader Goes From Scramble to Sold Out"
          excerpt="A prominent spiritual speaker was filling retreats through constant effort alone. Stramasa built the evergreen digital infrastructure that now fills all four annual retreat offerings — and grew digital course revenue 5x."
          industry="Speaker & Retreat Business"
          result="4 sold-out retreats, 5x digital course revenue"
          href="/case-studies/speaker-retreat-brand-growth/"
          imageSrc="https://images.pexels.com/photos/2695232/pexels-photo-2695232.jpeg?auto=compress&cs=tinysrgb&w=600"
        />

        <CaseStudyCard
          title="Online Spiritual Community Triples Paid Membership in 10 Months"
          excerpt="A thriving online spiritual community was growing slowly through word-of-mouth alone. Stramasa built a precision acquisition engine and redesigned onboarding — membership tripled and churn fell 42%."
          industry="Spiritual Community & Membership"
          result="3x paid membership, 42% churn reduction"
          href="/case-studies/spiritual-community-membership-growth/"
          imageSrc="https://images.pexels.com/photos/7551617/pexels-photo-7551617.jpeg?auto=compress&cs=tinysrgb&w=600"
        />

        <CaseStudyCard
          title="How a Meditation Center Tripled Organic Traffic in 8 Months"
          excerpt="A mindfulness and meditation center with almost zero digital presence partnered with Stramasa for SEO authority building — and achieved a 312% increase in organic traffic, alongside 4x retreat booking growth from search alone."
          industry="Wellness & Meditation"
          result="312% increase in organic search traffic in 8 months"
          href="/case-studies/meditation-center-seo-growth/"
          imageSrc="https://images.pexels.com/photos/3822622/pexels-photo-3822622.jpeg?auto=compress&cs=tinysrgb&w=600"
        />

        <CaseStudyCard
          title="Faith-Based Nonprofit Doubles Online Donations Through Digital Marketing"
          excerpt="A faith-based nonprofit serving underserved communities needed to grow their digital donor base. Stramasa's content-led strategy delivered a 2x increase in online donations and 3,200+ new email subscribers within 12 months."
          industry="Faith & Nonprofit"
          result="2x online donation revenue within 12 months"
          href="/case-studies/faith-nonprofit-growth/"
          imageSrc="https://images.pexels.com/photos/6646918/pexels-photo-6646918.jpeg?auto=compress&cs=tinysrgb&w=600"
        />

      </div>
    </div>
  </section>

  <!-- Why Stramasa Section -->
  <section class="section" style="background:var(--gray-50);border-top:1px solid var(--gray-200);">
    <div class="container why-inner">
      <div class="why-text">
        <span class="section-label">Our Track Record</span>
        <h2>Results Built on Expertise, Not Guesswork</h2>
        <p>Every case study here represents a real spiritual brand or faith-based organization that came to Stramasa with a specific growth challenge. Our approach is always the same: deep discovery, custom strategy, rigorous execution, and transparent reporting.</p>
        <p style="margin-top:16px;">The industries are different — meditation, nonprofit, church, wellness — but the foundation is consistent: topical SEO authority, authentic content, and conversion systems built for audiences that lead with values.</p>
        <a href="/contact/" class="btn btn-primary" style="margin-top:28px;">Discuss Your Growth Goals</a>
      </div>
      <div class="why-list">
        <div class="why-item">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <div>
            <strong>Spiritual niche specialists</strong>
            <p>We only work with spiritual, wellness, and faith-based brands — no generalist agency dilution.</p>
          </div>
        </div>
        <div class="why-item">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <div>
            <strong>SEO and GEO authority focus</strong>
            <p>Long-term compounding growth through search, not short-lived ad spend or quick fixes.</p>
          </div>
        </div>
        <div class="why-item">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <div>
            <strong>Values-first methodology</strong>
            <p>We build marketing that respects the authenticity expectations of spiritual communities.</p>
          </div>
        </div>
        <div class="why-item">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <div>
            <strong>Transparent, measurable results</strong>
            <p>Every engagement is grounded in clear KPIs and regular reporting on what's actually working.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CTASection
    headline="Ready to Become Our Next Case Study?"
    subheadline="Book a free strategy call and let's map out how Stramasa's Growth Programs can drive measurable results for your spiritual brand or organization."
    ctaLabel="Book a Free Strategy Call"
  />

  <GrowthFooter />
</Layout>

<style>
  .page-header {
    padding: 72px 0 56px;
    background: var(--gradient-hero);
  }

  .page-header .section-label { color: var(--teal-300); background: none; -webkit-text-fill-color: var(--teal-300); }

  .page-header h1 {
    color: var(--white);
    margin-bottom: 16px;
    margin-top: 8px;
  }

  .page-lead {
    font-size: 1.125rem;
    color: rgba(255,255,255,0.82);
    max-width: 680px;
    line-height: 1.7;
    margin: 0;
  }

  .results-strip {
    background: var(--charcoal-900);
    padding: 40px 0;
  }

  .results-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
  }

  .result-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    padding: 0 24px;
    border-right: 1px solid rgba(255,255,255,0.1);
  }

  .result-stat:last-child { border-right: none; }

  .result-num {
    font-size: 2rem;
    font-weight: 700;
    background: var(--gradient-primary);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1;
  }

  .result-lbl {
    font-size: 0.875rem;
    color: rgba(255,255,255,0.6);
    text-align: center;
    line-height: 1.4;
  }

  .case-studies-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    align-items: start;
  }

  .why-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 72px;
    align-items: start;
  }

  .why-text h2 { margin-bottom: 16px; }

  .why-text p {
    color: var(--charcoal-600);
    font-size: 1.0625rem;
    line-height: 1.75;
  }

  .why-list {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .why-item {
    display: flex;
    gap: 14px;
    align-items: flex-start;
  }

  .why-item svg {
    color: var(--teal-500);
    flex-shrink: 0;
    margin-top: 3px;
  }

  .why-item strong {
    display: block;
    font-size: 1rem;
    color: var(--charcoal-900);
    margin-bottom: 4px;
  }

  .why-item p {
    font-size: 0.9375rem;
    color: var(--charcoal-600);
    line-height: 1.6;
    margin: 0;
  }

  @media (max-width: 1024px) {
    .case-studies-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 900px) {
    .results-grid { grid-template-columns: repeat(2, 1fr); gap: 24px; }
    .result-stat { border-right: none; border-bottom: 1px solid rgba(255,255,255,0.1); padding-bottom: 24px; }
    .why-inner { grid-template-columns: 1fr; gap: 40px; }
  }

  @media (max-width: 640px) {
    .case-studies-grid { grid-template-columns: 1fr; }
    .results-grid { grid-template-columns: 1fr; }
    .result-stat { border-bottom: 1px solid rgba(255,255,255,0.1); padding-bottom: 20px; }
  }
</style>
