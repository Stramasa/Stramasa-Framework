---
import Layout from '../layouts/Layout.astro';
import GrowthHeader from '../components/GrowthHeader.astro';
import GrowthFooter from '../components/GrowthFooter.astro';
import Hero from '../components/Hero.astro';
import CaseStudyCard from '../components/CaseStudyCard.astro';
import ResourceCard from '../components/ResourceCard.astro';
import CTASection from '../components/CTASection.astro';
import SchemaMarkup from '../components/SchemaMarkup.astro';

const growthPrograms = [
  {
    icon: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>',
    title: 'Spiritual Marketing Strategy',
    description: 'Custom growth roadmaps built around your audience, niche, and business model — not generic templates.',
  },
  {
    icon: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>',
    title: 'SEO & GEO Authority',
    description: 'Rank on Google and appear in AI answer engines with topical authority strategies built for spiritual niches.',
  },
  {
    icon: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>',
    title: 'Content Marketing',
    description: 'Authority content that answers your audience\'s deepest questions and builds lasting organic reach.',
  },
  {
    icon: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>',
    title: 'Spiritual Branding & Identity',
    description: 'Brand identity, messaging frameworks, and narrative development so your positioning resonates authentically with the right audience.',
  },
  {
    icon: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8m-4-4v4"/></svg>',
    title: 'Digital Campaigns',
    description: 'Paid advertising on Google, Meta, and YouTube crafted for spiritually-aligned audiences and conversion goals.',
  },
  {
    icon: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>',
    title: 'Email Marketing',
    description: 'Nurture sequences, newsletters, and launch campaigns that deepen relationships and drive consistent revenue.',
  },
  {
    icon: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>',
    title: 'Community Growth',
    description: 'Build and activate loyal communities around your brand across email, social, and owned platforms.',
  },
  {
    icon: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>',
    title: 'Website & Conversion Optimization',
    description: 'Turn your digital presence into a client and booking machine with conversion-focused design and messaging.',
  },
];
---

<Layout
  title="Spiritual Marketing Agency | Stramasa — Growth Programs for Practitioners, Retreats & Brands"
  description="Stramasa is a specialized spiritual marketing agency offering proven growth programs for spiritual entrepreneurs, practitioners, retreat organizers, coaches, healers, and purpose-driven brands."
  canonical="/"
  category="Spiritual Marketing"
>
  <SchemaMarkup type="WebSite" name="Stramasa — Spiritual Marketing Agency" description="Specialized spiritual marketing growth programs for spiritual entrepreneurs, practitioners, retreats, and purpose-driven brands." url="https://spiritual.stramasa.com" />
  <SchemaMarkup type="Organization" />

  <GrowthHeader />

  <Hero
    badge="Stramasa Spiritual Marketing Agency"
    headline='Grow Your Spiritual Business with <span class="text-gradient">Expert Marketing</span>'
    subheadline="Stramasa partners with spiritual entrepreneurs, practitioners, retreat leaders, course creators, and purpose-driven brands. We handle the marketing, SEO, and digital growth systems — so you can focus on the work only you can do."
    ctaLabel="Get Your Growth Strategy"
    ctaHref="/contact/"
    ctaSecondaryLabel="See Growth Programs"
    ctaSecondaryHref="/spiritual-marketing/"
    heroImageSrc="/images/hero-sunset-lake.jpg"
  />

  <!-- Stats Strip -->
  <section class="stats-strip">
    <div class="container stats-grid">
      <div class="stat">
        <span class="stat-number">3x</span>
        <span class="stat-label">Average client growth</span>
      </div>
      <div class="stat">
        <span class="stat-number">150+</span>
        <span class="stat-label">Spiritual brands served</span>
      </div>
      <div class="stat">
        <span class="stat-number">Top 3</span>
        <span class="stat-label">Average Google rankings</span>
      </div>
      <div class="stat">
        <span class="stat-number">12+</span>
        <span class="stat-label">Spiritual niches</span>
      </div>
    </div>
  </section>

  <!-- Who We Serve — 3 Pillars -->
  <section class="section pillars-section">
    <div class="container">
      <div class="text-center" style="max-width:680px;margin:0 auto 56px;">
        <span class="section-label">Who We Serve</span>
        <h2>Proven Growth Programs for Every Stage of Your Spiritual Business</h2>
        <p style="color:var(--charcoal-600);font-size:1.0625rem;line-height:1.75;">Whether you're building a personal brand, filling retreats, or scaling a course — Stramasa has a proven growth program designed specifically for where you are and where you're going.</p>
      </div>
      <div class="pillars-grid">

        <div class="pillar-card">
          <div class="pillar-header">
            <div class="pillar-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            </div>
            <span class="pillar-number">01</span>
          </div>
          <h3>Grow Your Spiritual Practice & Personal Brand</h3>
          <div class="pillar-tags">
            <span class="pillar-tag">Coaches</span>
            <span class="pillar-tag">Healers</span>
            <span class="pillar-tag">Guides</span>
            <span class="pillar-tag">Teachers</span>
            <span class="pillar-tag">Breathwork</span>
            <span class="pillar-tag">Reiki</span>
            <span class="pillar-tag">Mentors</span>
            <span class="pillar-tag">Facilitators</span>
          </div>
          <p class="pillar-desc">Build visibility, attract aligned clients, and grow a loyal audience around your unique gifts — without spending your time on marketing.</p>
          <div class="pillar-footer">
            <ul class="pillar-outcomes">
              <li>
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                Get found by aligned clients searching for your work
              </li>
              <li>
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                Build a personal brand that communicates your authority
              </li>
              <li>
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                Fill your calendar without constant outreach
              </li>
            </ul>
            <a href="/contact/" class="pillar-cta">Start Growing Your Practice &rarr;</a>
          </div>
        </div>

        <div class="pillar-card pillar-card--accent">
          <div class="pillar-header">
            <div class="pillar-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            </div>
            <span class="pillar-number">02</span>
          </div>
          <h3>Fill Your Retreats, Events & Communities</h3>
          <div class="pillar-tags">
            <span class="pillar-tag">Retreat Organizers</span>
            <span class="pillar-tag">Workshops</span>
            <span class="pillar-tag">Group Programs</span>
            <span class="pillar-tag">Online Events</span>
            <span class="pillar-tag">Memberships</span>
            <span class="pillar-tag">Meditation</span>
          </div>
          <p class="pillar-desc">Move beyond one-to-one work. Build the audience and marketing systems that fill your retreats and spaces consistently.</p>
          <div class="pillar-footer">
            <ul class="pillar-outcomes">
              <li>
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                Sell out retreats and workshops with targeted campaigns
              </li>
              <li>
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                Build a community that grows your brand year-round
              </li>
              <li>
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                Launch memberships and group offers that scale
              </li>
            </ul>
            <a href="/contact/" class="pillar-cta">Fill Your Retreats &amp; Events &rarr;</a>
          </div>
        </div>

        <div class="pillar-card">
          <div class="pillar-header">
            <div class="pillar-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
            </div>
            <span class="pillar-number">03</span>
          </div>
          <h3>Scale Your Courses, Programs & Products</h3>
          <div class="pillar-tags">
            <span class="pillar-tag">Course Creators</span>
            <span class="pillar-tag">Authors</span>
            <span class="pillar-tag">Educators</span>
            <span class="pillar-tag">Digital Programs</span>
            <span class="pillar-tag">Spiritual Products</span>
          </div>
          <p class="pillar-desc">Transform your expertise into a scalable income stream — reaching people far beyond your current audience with the right marketing systems.</p>
          <div class="pillar-footer">
            <ul class="pillar-outcomes">
              <li>
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                Launch and evergreen your courses and digital programs
              </li>
              <li>
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                Reach buyers actively searching for what you offer
              </li>
              <li>
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                Build a scalable revenue model around your unique gifts
              </li>
            </ul>
            <a href="/contact/" class="pillar-cta">Scale Your Offers &rarr;</a>
          </div>
        </div>

        <!-- Community Card — full width -->
        <div class="community-card">
          <div class="community-left">
            <div class="community-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            </div>
            <div>
              <span class="section-label" style="color:var(--teal-400);background:rgba(20,184,166,0.12);">Woven Through Every Program</span>
              <h3 style="color:var(--white);margin-top:10px;">Community & Spiritual Brand Building</h3>
              <p style="color:rgba(255,255,255,0.78);font-size:0.9375rem;line-height:1.7;margin-top:8px;">Community isn't a separate service — it's the foundation that amplifies everything. Stramasa weaves community building and authentic brand positioning into every growth program we run.</p>
            </div>
          </div>
          <div class="community-pillars">
            <div class="community-pillar">
              <span class="cp-label">For Practitioners</span>
              <p>An engaged community amplifies your work, generates referrals, and turns followers into loyal clients over time.</p>
            </div>
            <div class="community-pillar">
              <span class="cp-label">For Events &amp; Retreats</span>
              <p>A nurtured community fills your retreats from your existing audience first — before you spend on advertising.</p>
            </div>
            <div class="community-pillar">
              <span class="cp-label">For Courses &amp; Products</span>
              <p>Community creates repeat buyers who purchase your next offer because they already belong to your brand.</p>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Growth Programs -->
  <section class="section programs-section">
    <div class="container">
      <div class="text-center" style="max-width:640px;margin:0 auto 56px;">
        <span class="section-label">Our Expertise</span>
        <h2>Spiritual Marketing Growth Programs That Deliver Results</h2>
        <p style="color:var(--charcoal-600);font-size:1.0625rem;line-height:1.75;">Stramasa's Growth Programs combine specialized spiritual marketing expertise, proven strategies, and full digital execution — designed specifically for spiritual businesses, not adapted from other industries.</p>
      </div>
      <div class="programs-grid">
        {growthPrograms.map((p) => (
          <div class="program-card">
            <div class="program-icon" set:html={p.icon}></div>
            <h3>{p.title}</h3>
            <p>{p.description}</p>
          </div>
        ))}
      </div>
      <div class="text-center" style="margin-top:48px;">
        <a href="/spiritual-marketing/" class="btn btn-outline">Explore All Growth Programs</a>
      </div>
    </div>
  </section>

  <!-- Why Stramasa -->
  <section class="section authority-section">
    <div class="container authority-inner">
      <div class="authority-content">
        <span class="section-label">Why Stramasa</span>
        <h2>A Spiritual Marketing Agency with Proven Specialization</h2>
        <p>Generic agencies apply the same framework to every client. Stramasa works exclusively in the spiritual space — meaning every strategy, every campaign, and every piece of content is built with a deep understanding of what moves spiritual audiences and what doesn't.</p>
        <ul class="authority-list">
          <li>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            Deep expertise in spiritual, wellness, and faith-based markets
          </li>
          <li>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            SEO and GEO programs that build long-term search dominance
          </li>
          <li>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            AI visibility optimization for Google SGE and AI answer engines
          </li>
          <li>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            Community-first approach: grow your audience, not just your traffic
          </li>
          <li>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            Transparent, measurable results — strategy backed by data
          </li>
        </ul>
        <a href="/about/" class="btn btn-primary" style="margin-top:8px;">Meet the Team</a>
      </div>
      <div class="authority-visual">
        <img
          src="/images/spiritual-marketing-services-stramasa.jpg"
          alt="Spiritual marketing growth strategy with Stramasa"
          width="520"
          height="400"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <!-- Supporting Expertise -->
  <section class="section" style="background:var(--gray-50);border-top:1px solid var(--gray-200);">
    <div class="container">
      <div class="text-center" style="max-width:640px;margin:0 auto 48px;">
        <span class="section-label">Additional Spiritual Marketing Expertise</span>
        <h2>Specialized Programs for Every Spiritual Organization</h2>
        <p style="color:var(--charcoal-600);font-size:1.0625rem;">Beyond personal brands and practitioners, Stramasa's growth programs extend to every kind of spiritual organization.</p>
      </div>
      <div class="expertise-grid">
        <a href="/church-marketing/" class="expertise-card">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
          <div>
            <h4>Church Marketing</h4>
            <p>Congregation growth, local SEO, giving campaigns, and digital outreach for churches and ministries.</p>
          </div>
          <span class="expertise-arrow">&rarr;</span>
        </a>
        <a href="/wellness-marketing/" class="expertise-card">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
          <div>
            <h4>Wellness Marketing</h4>
            <p>Yoga studios, retreat centers, and wellness brands seeking specialized digital marketing and growth.</p>
          </div>
          <span class="expertise-arrow">&rarr;</span>
        </a>
        <a href="/spiritual-branding/" class="expertise-card">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          <div>
            <h4>Spiritual Branding</h4>
            <p>Brand identity, positioning, and authority building for spiritual organizations and conscious brands.</p>
          </div>
          <span class="expertise-arrow">&rarr;</span>
        </a>
        <a href="/meditation-center-marketing/" class="expertise-card">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M12 8v4l2 2"/></svg>
          <div>
            <h4>Meditation Center Marketing</h4>
            <p>SEO and digital growth for meditation studios, mindfulness centers, and contemplative communities.</p>
          </div>
          <span class="expertise-arrow">&rarr;</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Case Studies Preview -->
  <section class="section">
    <div class="container">
      <div class="section-header text-center" style="max-width:640px;margin:0 auto 48px;">
        <span class="section-label">Results That Matter</span>
        <h2>Spiritual Marketing Case Studies</h2>
        <p style="color:var(--charcoal-600);font-size:1.0625rem;">See how Stramasa's growth programs have helped spiritual brands, practitioners, and organizations achieve measurable results.</p>
      </div>
      <div class="case-grid">
        <CaseStudyCard
          title="Spiritual Life Coach Quadruples Coaching Inquiries"
          excerpt="A spiritual life coach with a decade of expertise and a scattered online presence. Stramasa built brand positioning, an SEO content cluster, and a lead system that filled her calendar."
          industry="Spiritual Coaching"
          result="4x coaching inquiries, 220% organic traffic in 9 months"
          href="/case-studies/spiritual-coach-brand-growth/"
          imageSrc="https://images.pexels.com/photos/5717718/pexels-photo-5717718.jpeg?auto=compress&cs=tinysrgb&w=600"
        />
        <CaseStudyCard
          title="Conscious Speaker & Retreat Brand Sells Out All Programs"
          excerpt="A prominent spiritual speaker was filling retreats through constant effort. Stramasa built evergreen digital infrastructure that now sells out every retreat and grew course revenue 5x."
          industry="Speaker & Retreat Business"
          result="4 sold-out retreats, 5x digital course revenue"
          href="/case-studies/speaker-retreat-brand-growth/"
          imageSrc="https://images.pexels.com/photos/2695232/pexels-photo-2695232.jpeg?auto=compress&cs=tinysrgb&w=600"
        />
        <CaseStudyCard
          title="Spiritual Community Triples Paid Membership in 10 Months"
          excerpt="An online spiritual community growing only through word-of-mouth. Stramasa built a precision organic acquisition engine and redesigned onboarding — membership tripled and churn fell 42%."
          industry="Spiritual Community & Membership"
          result="3x paid membership, 42% churn reduction"
          href="/case-studies/spiritual-community-membership-growth/"
          imageSrc="https://images.pexels.com/photos/7551617/pexels-photo-7551617.jpeg?auto=compress&cs=tinysrgb&w=600"
        />
      </div>
      <div class="text-center" style="margin-top:40px;">
        <a href="/case-studies/" class="btn btn-outline">View All Case Studies</a>
      </div>
    </div>
  </section>

  <!-- Resources Preview -->
  <section class="section" style="background:var(--gray-50);border-top:1px solid var(--gray-200);">
    <div class="container">
      <div class="section-header text-center" style="max-width:640px;margin:0 auto 48px;">
