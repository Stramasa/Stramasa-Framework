---
import Layout from '../../layouts/Layout.astro';
import GrowthHeader from '../../components/GrowthHeader.astro';
import GrowthFooter from '../../components/GrowthFooter.astro';
import CTASection from '../../components/CTASection.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import SchemaMarkup from '../../components/SchemaMarkup.astro';
---

<Layout
  title="Spiritual Marketing Resources & Guides | Stramasa"
  description="Free guides, playbooks, and strategy resources for spiritual entrepreneurs, practitioners, churches, and wellness businesses. Practical spiritual marketing knowledge from Stramasa."
  canonical="/resources/"
  category="Resources"
>
  <SchemaMarkup
    type="WebSite"
    name="Spiritual Marketing Resources"
    description="Free marketing guides and strategy resources for spiritual brands, churches, and wellness organizations from Stramasa."
    url="https://spiritual.stramasa.com/resources/"
  />

  <GrowthHeader />

  <div class="container">
    <Breadcrumbs crumbs={[
      { label: 'Home', href: '/' },
      { label: 'Resources' },
    ]} />
  </div>

  <!-- Page Header -->
  <section class="page-header">
    <div class="container">
      <span class="section-label">Free Guides & Playbooks</span>
      <h1>Spiritual Marketing Resources</h1>
      <p class="page-lead">Practical guides, strategy frameworks, and playbooks to help spiritual brands, churches, and wellness businesses build lasting digital authority — completely free from Stramasa.</p>
    </div>
  </section>

  <!-- Resources Grid -->
  <section class="section">
    <div class="container">
      <div class="resources-grid">

        <a href="/resources/guide-one/" class="resource-card">
          <div class="resource-badge">Marketing Strategy</div>
          <div class="resource-meta">
            <span class="resource-read">12 min read</span>
            <span class="resource-date">January 2025</span>
          </div>
          <h2>The Complete Spiritual Marketing Guide for 2025</h2>
          <p>Everything your spiritual brand, church, or wellness business needs to build lasting digital authority — SEO, content strategy, AI visibility, brand positioning, and conversion optimization.</p>
          <div class="resource-topics">
            <span>SEO</span>
            <span>Content</span>
            <span>GEO / AI</span>
            <span>Conversion</span>
          </div>
          <span class="resource-cta">Read the Guide &rarr;</span>
        </a>

        <a href="/resources/seo-strategy-guide/" class="resource-card">
          <div class="resource-badge">SEO Guide</div>
          <div class="resource-meta">
            <span class="resource-read">10 min read</span>
            <span class="resource-date">February 2025</span>
          </div>
          <h2>SEO Strategy for Spiritual &amp; Wellness Brands</h2>
          <p>A practical, step-by-step SEO strategy guide for spiritual teachers, wellness coaches, churches, and faith-based organizations. Build lasting search authority that compounds over time.</p>
          <div class="resource-topics">
            <span>Keyword Research</span>
            <span>Topical Authority</span>
            <span>Technical SEO</span>
          </div>
          <span class="resource-cta">Read the Guide &rarr;</span>
        </a>

        <a href="/resources/content-playbook/" class="resource-card">
          <div class="resource-badge">Content Strategy</div>
          <div class="resource-meta">
            <span class="resource-read">9 min read</span>
            <span class="resource-date">March 2025</span>
          </div>
          <h2>Content Marketing Playbook for Churches &amp; Ministries</h2>
          <p>How churches and ministries can create content that attracts new visitors, retains members, and builds lasting digital authority — a proven playbook from Stramasa.</p>
          <div class="resource-topics">
            <span>Content Planning</span>
            <span>Sermon Repurposing</span>
            <span>Community Growth</span>
          </div>
          <span class="resource-cta">Read the Playbook &rarr;</span>
        </a>

      </div>
    </div>
  </section>

  <!-- Why These Resources -->
  <section class="section" style="background:var(--gray-50);border-top:1px solid var(--gray-200);">
    <div class="container why-inner">
      <div class="why-text">
        <span class="section-label">About These Resources</span>
        <h2>Built From Real-World Spiritual Marketing Experience</h2>
        <p>Every guide here is distilled from Stramasa's hands-on experience working with spiritual brands, churches, wellness businesses, and faith-based organizations. No generic marketing advice — only what actually works in spiritual and wellness niches.</p>
        <p style="margin-top:16px;">We publish these resources freely because we believe spiritual organizations deserve access to the same quality of marketing knowledge as any other industry. Better-informed organizations build better communities.</p>
        <a href="/contact/" class="btn btn-primary" style="margin-top:28px;">Get a Custom Strategy Instead</a>
      </div>
      <div class="why-list">
        <div class="why-item">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <div>
            <strong>Spiritual niche specific</strong>
            <p>Written for spiritual, wellness, and faith contexts — not adapted from e-commerce or B2B playbooks.</p>
          </div>
        </div>
        <div class="why-item">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <div>
            <strong>Actionable, not theoretical</strong>
            <p>Each guide gives you concrete steps you can implement, not vague principles to interpret on your own.</p>
          </div>
        </div>
        <div class="why-item">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <div>
            <strong>Updated for 2025</strong>
            <p>Covers modern SEO, GEO/AI visibility, and the current digital landscape spiritual brands operate in.</p>
          </div>
        </div>
        <div class="why-item">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <div>
            <strong>Free, no gate</strong>
            <p>No email required, no paywalls. Just useful knowledge to help your organization grow.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CTASection
    headline="Want a Strategy Built for Your Specific Brand?"
    subheadline="These guides give you the framework. Stramasa's Growth Programs apply it directly to your brand, audience, and goals with a custom strategy tailored to your spiritual business."
    ctaLabel="Book a Free Strategy Call"
  />

  <GrowthFooter />
</Layout>

<style>
  .page-header {
    padding: 72px 0 56px;
    background: var(--gradient-hero);
  }

  .page-header .section-label { color: var(--teal-300); background: none; -webkit-text-fill-color: var(--teal-300); }

  .page-header h1 {
    color: var(--white);
    margin-bottom: 16px;
    margin-top: 8px;
  }

  .page-lead {
    font-size: 1.125rem;
    color: rgba(255,255,255,0.82);
    max-width: 680px;
    line-height: 1.7;
    margin: 0;
  }

  .resources-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    align-items: start;
  }

  .resource-card {
    display: flex;
    flex-direction: column;
    gap: 14px;
    padding: 32px;
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: var(--radius-lg);
    text-decoration: none;
    transition: box-shadow 0.2s, border-color 0.2s, transform 0.2s;
  }

  .resource-card:hover {
    box-shadow: var(--shadow-md);
    border-color: var(--teal-400);
    transform: translateY(-2px);
    text-decoration: none;
  }

  .resource-badge {
    display: inline-block;
    align-self: flex-start;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--teal-500);
    background: rgba(20, 184, 166, 0.1);
    border: 1px solid rgba(20, 184, 166, 0.2);
    border-radius: 100px;
    padding: 4px 12px;
  }

  .resource-meta {
    display: flex;
    gap: 12px;
    align-items: center;
  }

  .resource-read, .resource-date {
    font-size: 0.8125rem;
    color: var(--gray-500);
  }

  .resource-card h2 {
    font-size: 1.125rem;
    color: var(--charcoal-900);
    line-height: 1.35;
    margin: 0;
  }

  .resource-card p {
    font-size: 0.9375rem;
    color: var(--charcoal-600);
    line-height: 1.65;
    margin: 0;
    flex: 1;
  }

  .resource-topics {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .resource-topics span {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--charcoal-700);
    background: var(--gray-100);
    border-radius: var(--radius-sm);
    padding: 3px 10px;
  }

  .resource-cta {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--blue-600);
    margin-top: 4px;
  }

  .why-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 72px;
    align-items: start;
  }

  .why-text h2 { margin-bottom: 16px; }

  .why-text p {
    color: var(--charcoal-600);
    font-size: 1.0625rem;
    line-height: 1.75;
  }

  .why-list {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .why-item {
    display: flex;
    gap: 14px;
    align-items: flex-start;
  }

  .why-item svg {
    color: var(--teal-500);
    flex-shrink: 0;
    margin-top: 3px;
  }

  .why-item strong {
    display: block;
    font-size: 1rem;
    color: var(--charcoal-900);
    margin-bottom: 4px;
  }

  .why-item p {
    font-size: 0.9375rem;
    color: var(--charcoal-600);
    line-height: 1.6;
    margin: 0;
  }

  @media (max-width: 1024px) {
    .resources-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 900px) {
    .why-inner { grid-template-columns: 1fr; gap: 40px; }
  }

  @media (max-width: 640px) {
    .resources-grid { grid-template-columns: 1fr; }
  }
</style>
